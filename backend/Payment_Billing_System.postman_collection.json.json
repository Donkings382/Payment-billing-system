              "raw": "{\n  \"customer_id\": {{customer_id_1}},\n  \"due_date\": \"2026-05-15T00:00:00\",\n  \"tax\": 10,\n  \"discount\": 100,\n  \"notes\": \"Q2 2026 Services - Web development and maintenance\",\n  \"items\": [\n    {\n      \"description\": \"Web Development - Frontend\",\n      \"quantity\": 40,\n      \"unit_price\": 150\n    },\n    {\n      \"description\": \"Web Development - Backend\",\n      \"quantity\": 35,\n      \"unit_price\": 175\n    },\n    {\n      \"description\": \"Database Optimization\",\n      \"quantity\": 10,\n      \"unit_price\": 200\n    },\n    {\n      \"description\": \"Monthly Hosting\",\n      \"quantity\": 3,\n      \"unit_price\": 99\n    }\n  ]\n}"
