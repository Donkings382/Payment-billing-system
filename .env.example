# ==========================================
# PAYMENT AND BILLING SYSTEM - ENVIRONMENT CONFIGURATION
# ==========================================
# This file contains environment variables for both backend and frontend
# Copy this file and configure appropriately for each service

# ==========================================
# BACKEND CONFIGURATION (FastAPI)
# ==========================================

# Server
APP_NAME=Payment Billing System
DEBUG=True
SECRET_KEY=your_super_secret_key_change_this_in_production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/payment_billing
DB_NAME=payment_billing
DB_USER=postgres
DB_PASSWORD=your_db_password
DB_HOST=localhost
DB_PORT=5432

# OR MongoDB (uncomment if using MongoDB)
# MONGODB_URI=mongodb://localhost:27017/payment_billing
# MONGODB_DB_NAME=payment_billing

# Redis (for caching and sessions)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# Payment Gateways
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_CURRENCY=usd

PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret
PAYPAL_MODE=sandbox
PAYPAL_WEBHOOK_ID=your_paypal_webhook_id

# Email Configuration (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_specific_password
EMAIL_FROM=noreply@yourcompany.com
EMAIL_FROM_NAME=Payment Billing System

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
ALLOWED_HOSTS=localhost,127.0.0.1

# File Storage
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880
ALLOWED_EXTENSIONS=pdf,jpg,png,doc,docx

# Logging
LOG_LEVEL=INFO
LOG_FILE=./logs/app.log

# ==========================================
# FRONTEND CONFIGURATION (React)
# ==========================================

# API Configuration
REACT_APP_API_URL=http://localhost:8000/api/v1
REACT_APP_WS_URL=ws://localhost:8000/ws

# Payment Gateway Keys (Public keys only)
REACT_APP_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
REACT_APP_PAYPAL_CLIENT_ID=your_paypal_client_id

# Feature Flags
REACT_APP_ENABLE_TWO_FACTOR=false
REACT_APP_ENABLE_DARK_MODE=true

# Analytics (Optional)
# REACT_APP_GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX
# REACT_APP_SENTRY_DSN=https://your_sentry_dsn

# App Configuration
REACT_APP_APP_NAME=Payment Billing System
REACT_APP_APP_VERSION=1.0.0